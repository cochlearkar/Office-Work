rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tasks — all reads/writes open (no auth in this app)
    match /tasks/{taskId} {
      allow read, write: if true;

      // Messages sub-collection under each task
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }

    // Call Reminders — all reads/writes open (no auth in this app)
    match /callReminders/{callId} {
      allow read, write: if true;
    }

    // High Alerts — admin-pushed urgent alerts that lock the recipient's screen
    match /highAlerts/{alertId} {
      allow read, write: if true;
    }

  }
}
